    "install:all": "cd server && npm install && cd ../client && npm install",
    "test": "jest"
  },
  "devDependencies": {
    "bcryptjs": "^3.0.3",
    "concurrently": "^9.1.2",
    "express": "^5.2.1",
    "jest": "^30.3.0",
    "jsonwebtoken": "^9.0.3",
    "selenium-webdriver": "^4.43.0",
    "supertest": "^7.2.2"
  }
}
